{
  "name": "geonera-scheduler",
  "version": "1.0.0",
  "description": "Distributed job scheduler built with Bun, Drizzle ORM, and RabbitMQ",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@scalar/hono-api-reference": "^0.11.8",
    "amqplib": "^2.0.1",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "pino": "^10.3.1",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3"
  }
}